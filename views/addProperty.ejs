<%- include('include/head.ejs') %>
<body>
<%- include("include/header.ejs"); %>
  <main>

    <!-- Add Property Form -->
    <div class="form-contact-container">
      <div class="card form-section">
        <h2>Add Property</h2>
        <p id="errorMsg" style="color:red; display:none;"></p>
        <p id="successMsg" style="color:green; display:none;"></p>
        <form id="addPropertyForm" enctype="multipart/form-data">
          <label for="title">Title</label>
          <input type="text" id="title" name="title" required>

          <label for="description">Description</label>
          <textarea id="description" name="description" required></textarea>

          <label for="type">Type</label>
          <select id="type" name="type">
            <option value="residential">Residential</option>
            <option value="commercial">Commercial</option>
            <option value="plot">Plot</option>
          </select>

          <label for="price">Price (₹)</label>
          <input type="number" id="price" name="price" required>

          <label for="city">City</label>
          <input type="text" id="city" name="city" required>

          <label for="address">Address</label>
          <input type="text" id="address" name="address">

          <label for="bedrooms">Bedrooms</label>
          <input type="number" id="bedrooms" name="bedrooms">

          <label for="bathrooms">Bathrooms</label>
          <input type="number" id="bathrooms" name="bathrooms">

          <label for="area">Area (sq ft)</label>
          <input type="number" id="area" name="area">

          <label for="ownerName">Owner Name</label>
          <input type="text" id="ownerName" name="ownerName">

          <label for="ownerPhone">Owner Phone</label>
          <input type="text" id="ownerPhone" name="ownerPhone">

          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="available">Available</option>
            <option value="sold">Sold</option>
            <option value="rented">Rented</option>
          </select>

          <label for="images">Images</label>
          <input type="file" id="images" name="images" accept="image/*" multiple>

          <button type="submit" class="btn" style="width:100%; margin-top:0.5rem;">Add Property</button>
        </form>
      </div>

      <div class="card get-in-touch-section">
        <h2>Get in Touch</h2>
        <p>Have questions or need help? Contact us for more information about Vedanta Residency or to schedule a visit.</p>
        <ul style="list-style:none; padding:0; margin:1rem 0; text-align:left;">
          <li style="margin-bottom:0.8rem;"><strong>Phone:</strong> +91 98765 43210</li>
          <li style="margin-bottom:0.8rem;"><strong>Email:</strong> info@vedantaresidency.com</li>
          <li><strong>Address:</strong> Near City Center, Muzaffarnagar, UP</li>
        </ul>
      </div>
    </div>

    <!-- All Properties List -->
    <section class="card" style="margin-top:1rem;">
      <h2 style="margin-bottom:1.5rem;">All Properties</h2>

      <!-- Filter Buttons -->
      <div style="display:flex; gap:0.8rem; flex-wrap:wrap; margin-bottom:1.5rem;">
        <button class="btn filter-btn" onclick="filterProps('all', this)" style="background:#33463e;">All</button>
        <button class="btn filter-btn" onclick="filterProps('available', this)" style="background:#43e97b; color:#000;">Available</button>
        <button class="btn filter-btn" onclick="filterProps('sold', this)" style="background:#e74c3c;">Sold</button>
        <button class="btn filter-btn" onclick="filterProps('rented', this)" style="background:#2196F3;">Rented</button>
      </div>

      <div id="allPropertiesList" style="display:flex; flex-direction:column; gap:1rem;">
        <p>Loading...</p>
      </div>
    </section>

  </main>
  <%- include("include/footer.ejs"); %>

  <script>
    let allProps = [];

    // load properties on page load
    async function loadProperties() {
      try {
        const res = await fetch('/property/all');
        const data = await res.json();
        if (data.success) {
          allProps = data.data;
          renderProps(allProps);
        }
      } catch (err) {
        document.getElementById('allPropertiesList').innerHTML = '<p>Failed to load properties.</p>';
      }
    }

    function renderProps(properties) {
      const container = document.getElementById('allPropertiesList');

      if (!properties.length) {
        container.innerHTML = '<p>No properties found.</p>';
        return;
      }

      container.innerHTML = properties.map(p => `
        <div style="display:flex; gap:1rem; align-items:center; background:rgba(255,255,255,0.08); border-radius:10px; padding:1rem; flex-wrap:wrap;">
          <img src="${p.images?.[0] || 'https://images.unsplash.com/photo-1460518451285-97b6aa326961?auto=format&fit=crop&w=120&q=80'}"
            style="width:100px; height:80px; object-fit:cover; border-radius:8px; flex-shrink:0;">
          <div style="flex:1; min-width:180px;">
            <h4 style="margin:0 0 0.3rem 0;">${p.title}</h4>
            <p style="margin:0 0 0.3rem 0; font-size:0.9rem;">${p.city || ''} ${p.type ? '· ' + p.type : ''}</p>
            <strong>₹ ${Number(p.price).toLocaleString('en-IN')}</strong>
          </div>
          <div style="display:flex; gap:0.5rem; align-items:center; flex-wrap:wrap;">
            <select onchange="updateStatus('${p._id}', this.value)" style="padding:0.4rem; border-radius:5px; background:#33463e; color:#fff; border:none; cursor:pointer;">
              <option value="available" ${p.status === 'available' ? 'selected' : ''}>Available</option>
              <option value="sold" ${p.status === 'sold' ? 'selected' : ''}>Sold</option>
              <option value="rented" ${p.status === 'rented' ? 'selected' : ''}>Rented</option>
            </select>
            <button onclick="deleteProperty('${p._id}')" style="background:#e74c3c; color:#fff; border:none; border-radius:5px; padding:0.4rem 0.8rem; cursor:pointer;">Delete</button>
          </div>
        </div>
      `).join('');
    }

    function filterProps(status, btn) {
      document.querySelectorAll('.filter-btn').forEach(b => b.style.opacity = '0.5');
      btn.style.opacity = '1';
      if (status === 'all') renderProps(allProps);
      else renderProps(allProps.filter(p => p.status === status));
    }

    async function updateStatus(id, status) {
      try {
        await fetch(`/property/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status })
        });
        // refresh list
        await loadProperties();
      } catch (err) {
        alert('Failed to update status');
      }
    }

    async function deleteProperty(id) {
      if (!confirm('Are you sure you want to delete this property?')) return;
      try {
        await fetch(`/property/${id}`, { method: 'DELETE' });
        await loadProperties();
      } catch (err) {
        alert('Failed to delete property');
      }
    }

    // add property form submit
    document.getElementById('addPropertyForm').addEventListener('submit', async function(e) {
      e.preventDefault();

      const errorMsg = document.getElementById('errorMsg');
      const successMsg = document.getElementById('successMsg');
      errorMsg.style.display = 'none';
      successMsg.style.display = 'none';

      try {
        const res = await fetch('/property/add', {
          method: 'POST',
          body: new FormData(this)
        });

        const data = await res.json();

        if (data.success) {
          successMsg.style.display = 'block';
          successMsg.textContent = 'Property added successfully!';
          this.reset();
          await loadProperties(); // refresh list without redirect
        } else {
          errorMsg.style.display = 'block';
          errorMsg.textContent = data.message || 'Something went wrong';
        }
      } catch (err) {
        errorMsg.style.display = 'block';
        errorMsg.textContent = 'Server error, try again';
      }
    });

    loadProperties();
  </script>
</body>
</html>