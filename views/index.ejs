<%- include('include/head.ejs') %>
<link rel="stylesheet" href="/css/index.css">

<body>
  <%- include("include/header.ejs"); %>
  <main>
    <!-- Image Slider -->
    <div class="slider" id="mainSlider">
      <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=800&q=80" class="active" alt="Modern Apartment">
      <img src="https://images.unsplash.com/photo-1460518451285-97b6aa326961?auto=format&fit=crop&w=800&q=80" alt="Luxury Living Room">
      <img src="https://images.unsplash.com/photo-1512918728675-ed5a9ecdebfd?auto=format&fit=crop&w=800&q=80" alt="Cozy Flat">
      <img src="https://images.unsplash.com/photo-1507089947368-19c1da9775ae?auto=format&fit=crop&w=800&q=80" alt="Elegant Villa">
      <img src="https://cdn.confident-group.com/wp-content/uploads/2024/12/27103036/types-of-real-estate-overview-scaled.jpg" alt="Real Estate Overview">
      <div class="slider-controls">
        <button id="prevSlide">&#10094;</button>
        <button id="nextSlide">&#10095;</button>
      </div>
    </div>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-content">
        <h2>Find Your Dream Home in Muzaffarnagar</h2>
        <p>Welcome to Vedanta Residency, your trusted real estate partner in Muzaffarnagar, UP. Discover premium properties, modern amenities, and a vibrant community.</p>
        <a href="/register" class="btn">Get Started</a>
      </div>
      <div class="hero-img">
        <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=600&q=80" alt="Modern Apartment">
      </div>
    </section>

    <!-- About -->
    <section class="card">
      <h3>About Vedanta Residency</h3>
      <p>Vedanta Residency offers a blend of luxury, comfort, and convenience. Our properties are designed to provide a modern lifestyle with all the amenities you need. Enjoy lush green surroundings, 24/7 security, and a vibrant community in the heart of Muzaffarnagar.</p>
      <div class="about-images">
        <img src="https://images.unsplash.com/photo-1465101046530-73398c7f28ca?auto=format&fit=crop&w=300&q=80" alt="Green Spaces">
        <img src="https://images.unsplash.com/photo-1501594907352-04cda38ebc29?auto=format&fit=crop&w=300&q=80" alt="Modern Amenities">
        <img src="https://images.unsplash.com/photo-1464983953574-0892a716854b?auto=format&fit=crop&w=300&q=80" alt="Community">
      </div>
    </section>

    <!-- Featured Properties - MongoDB se -->
    <section class="featured">
      <h3>Featured Properties</h3>
      <div class="property-list" id="featuredList">
        <p>Loading...</p>
      </div>
    </section>

    <!-- Project Site Profile -->
    <section class="project-profile card">
      <h3>Project Site Profile</h3>
      <p>Vedanta Residency is strategically located in the heart of Muzaffarnagar, offering easy access to major landmarks, schools, hospitals, and shopping centers.</p>
      <ul>
        <li><strong>Location:</strong> Near City Center, Muzaffarnagar, UP</li>
        <li><strong>Total Area:</strong> 10 Acres</li>
        <li><strong>Green Spaces:</strong> 60% open & landscaped</li>
        <li><strong>Key Amenities:</strong> Clubhouse, Swimming Pool, Gym, Kids Play Area, 24/7 Security</li>
        <li><strong>Connectivity:</strong> Close to schools, hospitals, and shopping malls</li>
      </ul>
    </section>

    <!-- Statistics -->
    <section class="statistics-section card">
      <h3>Our Achievements</h3>
      <div class="stats-container">
        <div class="stat-item">
          <div class="stat-number">500+</div>
          <div class="stat-label">Happy Customers</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">15+</div>
          <div class="stat-label">Projects Delivered</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">8+</div>
          <div class="stat-label">Ongoing Projects</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">12+</div>
          <div class="stat-label">Years Experience</div>
        </div>
      </div>
    </section>

    <!-- Awards -->
    <section class="awards-section card">
      <h3>Awards & Recognition</h3>
      <p>Recognized for excellence in real estate development and customer satisfaction</p>
      <div class="awards-container">
        <div class="award-item">
          <i class="fas fa-trophy"></i>
          <h4>Best Developer 2024</h4>
          <p>Real Estate Excellence Award</p>
        </div>
        <div class="award-item">
          <i class="fas fa-star"></i>
          <h4>Customer Choice</h4>
          <p>Most Trusted Brand</p>
        </div>
        <div class="award-item">
          <i class="fas fa-medal"></i>
          <h4>Quality Excellence</h4>
          <p>Construction Standards</p>
        </div>
      </div>
    </section>

    <!-- Premium Properties - MongoDB se -->
    <section class="enhanced-properties card">
      <h3>Premium Properties</h3>
      <div class="property-grid" id="premiumGrid">
        <p>Loading...</p>
      </div>
    </section>

    <!-- Real Estate Types -->
    <section class="card" style="text-align:center; margin-bottom:2rem;">
      <h3 style="color:var(--accent);">Types of Real Estate Overview</h3>
      <img src="https://cdn.confident-group.com/wp-content/uploads/2024/12/27103036/types-of-real-estate-overview-scaled.jpg" alt="Types of Real Estate Overview" style="max-width:100%;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,0.18);margin:1.5rem 0;">
    </section>
  </main>

  <!-- Get in Touch Modal -->
  <div id="getInTouchModal" class="modal-overlay">
    <div class="modal-content">
      <span class="close-modal" id="closeGetInTouch">&times;</span>
      <h3>Get in Touch</h3>
      <p>Have questions or need help? Contact us for more information about Vedanta Residency or to schedule a visit.</p>
      <ul>
        <li><strong>Phone:</strong> +91 98765 43210</li>
        <li><strong>Email:</strong> info@vedantaresidency.com</li>
        <li><strong>Address:</strong> A2z Road, Muzaffarnagar</li>
      </ul>
    </div>
  </div>

  <%- include("include/footer.ejs"); %>
  <script src="/js/slider.js"></script>
  <script src="/js/index.js"></script>
  <script>
    fetch('/property/all')
      .then(r => r.json())
      .then(data => {
        if (!data.success || !data.data.length) {
          document.getElementById('featuredList').innerHTML = '<p>No properties found.</p>';
          document.getElementById('premiumGrid').innerHTML = '<p>No properties found.</p>';
          return;
        }

        const properties = data.data;
        const badges = ['PREMIUM', 'NEW', 'POPULAR'];
        const badgeClasses = ['badge-premium', 'badge-new', 'badge-popular'];
        const fallbackImg = 'https://images.unsplash.com/photo-1460518451285-97b6aa326961?auto=format&fit=crop&w=400&q=80';

        document.getElementById('featuredList').innerHTML = properties.slice(0, 3).map(p => `
          <div class="property-card" onclick="window.location.href='/propertyDetail?id=${p._id}'" style="cursor:pointer;">
            <img src="${p.images?.[0] || fallbackImg}" alt="${p.title}">
            <div class="info">
              <h4>${p.title}</h4>
              <p>${p.description || ''}</p>
              <div class="price">₹ ${Number(p.price).toLocaleString('en-IN')}</div>
            </div>
          </div>
        `).join('');

        document.getElementById('premiumGrid').innerHTML = properties.slice(0, 3).map((p, i) => `
          <div class="premium-property-card" onclick="window.location.href='/propertyDetail?id=${p._id}'" style="cursor:pointer;">
            <div class="property-image-container">
              <img src="${p.images?.[0] || fallbackImg}" alt="${p.title}" class="property-image">
              <div class="property-badge ${badgeClasses[i]}">${badges[i]}</div>
            </div>
            <div class="property-content">
              <h4>${p.title}</h4>
              <p>${p.description || ''}</p>
              <div class="property-footer">
                <div class="property-price">₹ ${Number(p.price).toLocaleString('en-IN')}</div>
                <button class="btn property-btn">View Details</button>
              </div>
            </div>
          </div>
        `).join('');
      })
      .catch(err => console.error('Properties load failed:', err));
  </script>
</body>
</html>