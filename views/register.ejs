<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - Vedanta Residency</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include("include/header.ejs") %>
  <main>
    <div class="auth-container">

      <div class="card auth-form-card">
        <h2>Create Account</h2>
        <p class="subtitle">Join Vedanta Residency and find your dream home.</p>
        <p id="errorMsg" class="error-msg"></p>
        <p id="successMsg" class="success-msg"></p>
        <form id="registerForm">
          <label for="name">Full Name</label>
          <input type="text" id="name" name="name" placeholder="John Doe" required>
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" placeholder="john@example.com" required>
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="Create a strong password" required>
          <button type="submit" class="btn auth-submit-btn">Create Account</button>
        </form>
        <p class="footer-link">Already have an account? <a href="/login">Login</a></p>
      </div>

      <div class="card auth-features-card">
        <h2>Why Join Us?</h2>
        <div class="auth-feature-item">
          <div class="auth-feature-icon">🏠</div>
          <div>
            <h4>Premium Listings</h4>
            <p>Access hundreds of verified residential and commercial properties in Muzaffarnagar.</p>
          </div>
        </div>
        <div class="auth-feature-item">
          <div class="auth-feature-icon">🔒</div>
          <div>
            <h4>Secure & Trusted</h4>
            <p>Your data is safe with us. We never share your personal information with third parties.</p>
          </div>
        </div>
        <div class="auth-feature-item">
          <div class="auth-feature-icon">📞</div>
          <div>
            <h4>Direct Owner Contact</h4>
            <p>Connect directly with property owners — no middlemen, no hidden charges.</p>
          </div>
        </div>
        <div class="auth-feature-item">
          <div class="auth-feature-icon">⚡</div>
          <div>
            <h4>Quick & Easy</h4>
            <p>Register in seconds and start browsing properties instantly.</p>
          </div>
        </div>
      </div>

    </div>
  </main>
  <%- include("include/footer.ejs"); %>

  <script>
    document.getElementById('registerForm').addEventListener('submit', async function(e) {
      e.preventDefault();

      const name = document.getElementById('name').value;
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      const errorMsg = document.getElementById('errorMsg');
      const successMsg = document.getElementById('successMsg');

      errorMsg.style.display = 'none';
      successMsg.style.display = 'none';

      try {
        const res = await fetch('/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, password })
        });

        const data = await res.json();

        if (data.success) {
          localStorage.setItem('userId', data.userId);
          localStorage.setItem('userName', name);
          localStorage.setItem('token', data.token);
          successMsg.style.display = 'block';
          successMsg.textContent = 'Registration successful! Redirecting...';
          setTimeout(() => window.location.href = '/dashboard', 1500);
        } else {
          errorMsg.style.display = 'block';
          errorMsg.textContent = data.message || 'Registration failed';
        }
      } catch (err) {
        errorMsg.style.display = 'block';
        errorMsg.textContent = 'Something went wrong, try again';
      }
    });
  </script>
</body>
</html>